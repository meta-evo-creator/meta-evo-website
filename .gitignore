# GitHub Pages 部署忽略文件

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 依赖目录
node_modules/
bower_components/

# 构建输出
dist/
build/
out/
.next/
.nuxt/

# 缓存文件
.cache/
.tmp/
temp/

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 证书文件
*.pem
*.crt
*.key

# 测试覆盖
coverage/
.nyc_output/

# 其他
*.bak
*.tmp
*.orig
*.patch

# 本地开发文件（如果有）
.dev/
.local/

# 特定于本项目的忽略
# 备份文件
backup/
*.backup

# 临时生成文件
*.temp
*.tmp

# 大型媒体文件（如果需要单独管理）
assets/images/raw/
assets/videos/

# 开发工具生成文件
.sass-cache/
.stylelintcache

# 文档生成文件
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata